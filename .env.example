# Operato — environment variables
#
# Copy to `.env` and fill in. NEVER commit `.env`.
# Only NEXT_PUBLIC_* values reach the browser — never put a secret behind that prefix.
# Full context for each block: docs/stack-changes.md

# ── Database (Neon Postgres) ────────────────────────────────────────────────
# App connection — full read/write, used by the main PrismaClient.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# AI connection — a DEDICATED READ-ONLY Postgres role, used by a SEPARATE
# PrismaClient for the text-to-SQL path only. This is a security boundary, not
# a convenience: it is what makes a model-generated write impossible rather
# than merely unlikely. See docs/plan-code-review.md §"read-only role".
DATABASE_URL_AI="postgresql://operato_ai_ro:PASSWORD@HOST/DB?sslmode=require"

# ── Better Auth ─────────────────────────────────────────────────────────────
# >= 32 chars. Generate: openssl rand -base64 32
# Rotating this invalidates every existing session.
BETTER_AUTH_SECRET=""
# Must match the deployed origin in production, or OAuth callbacks + cookie
# domains break.
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# Optional Google social sign-in (only if enabled in src/lib/auth.ts)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Razorpay (billing) ──────────────────────────────────────────────────────
# Server-only.
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET=""
# NOTE: the webhook secret is a value YOU choose in Dashboard → Settings →
# Webhooks. It is NOT the key secret. Mixing them up is the classic bug.
RAZORPAY_WEBHOOK_SECRET=""
# The shared "Operato Pro" plan id, created once per environment.
RAZORPAY_PRO_PLAN_ID="plan_xxxxxxxxxxxxxx"

# Client-safe: the Key ID is public by design (Checkout.js needs it).
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxx"

# ── Google Gemini (AI, via the Vercel AI SDK) ───────────────────────────────
# The @ai-sdk/google provider reads this name specifically — don't rename it.
GOOGLE_GENERATIVE_AI_API_KEY=""

# ── Uploadthing (menu/catalog images) ───────────────────────────────────────
# Verify the expected var name against the installed uploadthing major before
# relying on this — it changed between v6 and v7.
UPLOADTHING_TOKEN=""

# ── Vercel Cron (weekly summary) ────────────────────────────────────────────
# The cron route must reject any request whose Authorization header doesn't
# carry this. An unprotected cron route is a public endpoint.
CRON_SECRET=""
