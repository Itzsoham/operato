{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run dev:*)",
      "Bash(npm run build:*)",
      "Bash(npm run start:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm run test:e2e:*)",
      "Bash(npm run db:generate:*)",
      "Bash(npm run db:migrate:*)",
      "Bash(npm run db:seed:*)",
      "Bash(npm run db:studio:*)",
      "Bash(npm install:*)",
      "Bash(npm ci:*)",
      "Bash(npm audit:*)",
      "Bash(npx tsc --noEmit:*)",
      "Bash(npx prisma generate:*)",
      "Bash(npx prisma format:*)",
      "Bash(npx prisma validate:*)",
      "Bash(npx prisma migrate dev:*)",
      "Bash(npx prisma migrate status:*)",
      "Bash(npx prisma migrate deploy:*)",
      "Bash(npx prisma db seed:*)",
      "Bash(npx prisma studio:*)",
      "Bash(npx @better-auth/cli generate:*)",
      "Bash(npx shadcn add:*)",
      "Bash(npx shadcn init:*)",
      "Bash(npx playwright test:*)",
      "Bash(npx playwright install:*)",
      "Bash(npx playwright show-report:*)",
      "Bash(npx next typegen:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Read(./node_modules/next/dist/docs/**)",
      "Read(./docs/**)",
      "Read(./prisma/**)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.production)",
      "Edit(./prisma/migrations/**)",
      "Write(./prisma/migrations/**)",
      "Bash(npx prisma migrate reset:*)",
      "Bash(npx prisma db push:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)"
    ]
  }
}
